generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(patient)
  createdAt    DateTime @default(now()) @map("created_at")

  patient   Patient?
  clinician Clinician?

  @@map("users")
}

enum Role {
  patient
  clinician
  admin
}

model Patient {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  fullName          String   @map("full_name")
  dob               DateTime
  gender            String
  phone             String?
  address           String?
  allergies         String[]
  chronicConditions String[] @map("chronic_conditions")
  bloodType         String?  @map("blood_type")
  emergencyContact  String?  @map("emergency_contact")
  createdAt         DateTime @default(now()) @map("created_at")

  user               User                @relation(fields: [userId], references: [id])
  medicalRecords     MedicalRecord[]
  labResults         LabResult[]
  uploadedDocuments  UploadedDocument[]
  aiInsights         AIInsight[]
  appointments       Appointment[]
  dataSharingConsents DataSharingConsent[]
  clinicianNotes     ClinicianNote[]

  @@index([userId])
  @@map("patients")
}

model Clinician {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  fullName     String   @map("full_name")
  specialty    String
  facilityName String   @map("facility_name")
  licenseNo    String?  @map("license_no")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  notes        ClinicianNote[]

  @@index([userId])
  @@map("clinicians")
}

model Facility {
  id      String     @id @default(uuid())
  name    String
  type    FacilityType
  address String?
  phone   String?

  medicalRecords     MedicalRecord[]
  labResults         LabResult[]
  dataSharingConsents DataSharingConsent[]

  @@map("facilities")
}

enum FacilityType {
  hospital
  lab
  clinic
}

model MedicalRecord {
  id           String       @id @default(uuid())
  patientId    String       @map("patient_id")
  facilityId   String       @map("facility_id")
  recordType   RecordType   @map("record_type")
  title        String
  recordDate   DateTime     @map("record_date")
  content      String
  sourceFormat SourceFormat @map("source_format")
  clinician    String?
  createdAt    DateTime     @default(now()) @map("created_at")

  patient  Patient  @relation(fields: [patientId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([patientId])
  @@index([recordDate])
  @@map("medical_records")
}

enum RecordType {
  visit
  prescription
  imaging
  note
  surgery
  vaccination
}

enum SourceFormat {
  structured
  unstructured
  imaging
}

model LabResult {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  facilityId     String   @map("facility_id")
  testName       String   @map("test_name")
  value          Float
  unit           String
  referenceRange String   @map("reference_range")
  testDate       DateTime @map("test_date")
  category       String   @default("general")
  isAbnormal     Boolean  @default(false) @map("is_abnormal")
  createdAt      DateTime @default(now()) @map("created_at")

  patient  Patient  @relation(fields: [patientId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([patientId])
  @@index([testDate])
  @@map("lab_results")
}

model UploadedDocument {
  id            String      @id @default(uuid())
  patientId     String      @map("patient_id")
  fileName      String      @map("file_name")
  fileUrl       String      @map("file_url")
  uploadDate    DateTime    @default(now()) @map("upload_date")
  ocrStatus     OcrStatus   @default(pending) @map("ocr_status")
  extractedText String?     @map("extracted_text")
  documentType  String?     @map("document_type")
  fileSize      Int?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("uploaded_documents")
}

enum OcrStatus {
  pending
  processing
  complete
  failed
}

model AIInsight {
  id             String        @id @default(uuid())
  patientId      String        @map("patient_id")
  insightText    String        @map("insight_text")
  metric         String?
  trendDirection TrendDirection @map("trend_direction")
  severity       String        @default("info")
  category       String        @default("general")
  generatedAt    DateTime      @default(now()) @map("generated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("ai_insights")
}

enum TrendDirection {
  up
  down
  stable
  fluctuating
}

model Appointment {
  id          String            @id @default(uuid())
  patientId   String            @map("patient_id")
  clinicianId String            @map("clinician_id")
  scheduledAt DateTime          @map("scheduled_at")
  status      AppointmentStatus @default(requested)
  reason      String?
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at")

  patient   Patient   @relation(fields: [patientId], references: [id])
  clinician Clinician @relation(fields: [clinicianId], references: [id])

  @@index([patientId])
  @@index([clinicianId])
  @@map("appointments")
}

enum AppointmentStatus {
  requested
  confirmed
  completed
  cancelled
}

model DataSharingConsent {
  id         String   @id @default(uuid())
  patientId  String   @map("patient_id")
  facilityId String   @map("facility_id")
  granted    Boolean  @default(false)
  updatedAt  DateTime @updatedAt @map("updated_at")

  patient  Patient  @relation(fields: [patientId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@unique([patientId, facilityId])
  @@map("data_sharing_consents")
}

model ClinicianNote {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  clinicianId String   @map("clinician_id")
  noteText    String   @map("note_text")
  createdAt   DateTime @default(now()) @map("created_at")

  patient   Patient   @relation(fields: [patientId], references: [id])
  clinician Clinician @relation(fields: [clinicianId], references: [id])

  @@index([patientId])
  @@map("clinician_notes")
}
